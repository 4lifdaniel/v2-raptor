# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
/frontend/node_modules
/frontend/.pnp
/frontend/.pnp.js
/frontend/.yarn/install-state.gz


# testing
/coverage

# next.js
/.next/
/out/
/frontend/.next/
/frontend/out/

# production
/build
/frontend/build

# misc
.DS_Store
*.pem
/frontend/.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

